# ─────────────────────────────────────────────────────────────────────────────
# Umuturanyi — environment configuration
# Copy to `.env` and adjust. Never commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (zero-config local dev):
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL (production / docker-compose):
# DATABASE_URL="postgresql://umuturanyi:umuturanyi@localhost:5432/umuturanyi?schema=public"

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate strong secrets in production: `openssl rand -hex 48`
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-0000000000000000
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-1111111111111
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── Redis (optional — falls back to in-memory when unset) ─────────────────────
# REDIS_URL=redis://localhost:6379

# ── File storage ─────────────────────────────────────────────────────────────
# driver: "local" (disk) or "s3"
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# S3 / compatible (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=umuturanyi
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ── Email (optional — logs to console when unset) ────────────────────────────
SMTP_URL=
EMAIL_FROM="Umuturanyi <noreply@umuturanyi.rw>"

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ── Frontend (apps/web) ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
