{
  "expo": {
    "name": "Umuturanyi",
    "slug": "umuturanyi",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "umuturanyi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FFF4E8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "rw.umuturanyi.app"
    },
    "android": {
      "package": "rw.umuturanyi.app",
      "adaptiveIcon": {
        "backgroundColor": "#EF6320"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Umuturanyi isaba uruhushya rwo kugera ku mafoto zawe kugira ngo uzikoreshe mu bicuruzwa n'amatangazo.",
          "cameraPermission": "Umuturanyi isaba uruhushya rwa kamera kugira ngo ufate ifoto y'igicuruzwa."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
